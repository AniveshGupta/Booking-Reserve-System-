PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/booking-system
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Get free test-mode keys from https://dashboard.razorpay.com/ (Settings > API Keys)
# Test mode needs no business verification, just a signup.
RAZORPAY_KEY_ID=rzp_test_TBhOWH39O4kfkz
RAZORPAY_KEY_SECRET=pw9zZV4ea5hvIX0yfP0wuvb3

# Flat reservation deposit charged per booking, in INR
BOOKING_DEPOSIT_INR=200

# Get this from https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, type "Web application")
# Must match the same value used in frontend/.env as VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
